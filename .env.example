# Local app URL used by Stripe redirects and Supabase OAuth callbacks.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Supabase project settings: Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe test mode: Developers -> API keys and Developers -> Webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe recurring Price IDs for subscription Checkout.
# Keep these server-only. They are read in /api/billing/checkout.
STRIPE_PRICE_EXPLORER_MONTH=
STRIPE_PRICE_EXPLORER_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=

# Amadeus Self-Service app credentials for Flight Offers.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Duffel API key for Offer Requests.
DUFFEL_API_KEY=

# Seats.aero partner API. Use commercially only after explicit authorization.
SEATS_AERO_API_KEY=
SEATS_AERO_COMMERCIAL_OK=false
